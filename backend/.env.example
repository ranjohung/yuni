# 「与你」后端环境变量配置

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=yu_ni

# JWT密钥
JWT_SECRET=yu-ni-dev-key

# DeepSeek API（不设置则自动降级到Ollama本地模型）
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama本地LLM（降级备用）
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b

# Redis（非强依赖，可留空）
REDIS_URL=redis://localhost:6379
